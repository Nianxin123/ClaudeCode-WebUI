{
  "name": "claude-code-web-ui",
  "version": "1.0.0",
  "description": "Claude Code 本地Web UI界面",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "pkg . --targets node18-win-x64 --output dist/claude-code-web-ui.exe"
  },
  "pkg": {
