    "express": "^4.18.2",
    "highlight.js": "^11.9.0",
    "mammoth": "^1.12.0",
    "marked": "^12.0.0",
    "multer": "^1.4.5-lts.1",
    "officeparser": "^7.2.1",
    "textract": "^2.5.0"
  },
  "keywords": [
    "claude",
    "ai",
    "web-ui"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "pkg": "^5.8.1"
  }
